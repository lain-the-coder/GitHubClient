{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ExternalApis": {
    "GitHubApi": {
      "BaseUrl": "https://api.github.com",
      "TimeoutSeconds": 30
    },
    "AuthorizationApi": {
      "AuthMode": "StaticToken",
      "StaticToken": "your-github-token",
      "TokenUrl": "",
      "ClientId": "",
      "ClientSecret": "",
      "GrantType": "client_credentials"
    }
  }
}